#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

&trackball {
    automouse-layer = <1>;
    scroll-layers = <2>;
};

/ {
    combos {
        compatible = "zmk,combos";

        tab {
            bindings = <&kp TAB>;
            key-positions = <11 12>;
        };

        shift_tab {
            bindings = <&kp LS(TAB)>;
            key-positions = <12 13>;
        };

        muhennkann {
            bindings = <&to_layer_0 INT_MUHENKAN>;
            key-positions = <11 10>;
        };

        double_quotation {
            bindings = <&kp DOUBLE_QUOTES>;
            key-positions = <20 21>;
        };

        eq {
            bindings = <&kp EQUAL>;
            key-positions = <24 25>;
        };
    };

    macros {
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };

        // 【追加】ピンチズームイン用マクロ（Commandを押しながらスクロールアップ）
        zoom_in_macro: zoom_in_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LCMD>, <&msc SCRL_UP>, <&macro_release &kp LCMD>;
            label = "ZOOM_IN_MACRO";
        };

        // 【追加】ピンチズームアウト用マクロ（Commandを押しながらスクロールダウン）
        zoom_out_macro: zoom_out_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LCMD>, <&msc SCRL_DOWN>, <&macro_release &kp LCMD>;
            label = "ZOOM_OUT_MACRO";
        };
    };

    behaviors {
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        // 【追加】エンコーダーの回転を上記のマクロに結びつける設定
        encoder_pinch_zoom: encoder_pinch_zoom {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&zoom_in_macro>, <&zoom_out_macro>;
            tap-ms = <10>; // 回転時の追従性を高めるため短めに調整
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q             &kp W         &kp E         &kp R                        &kp T                                                                                      &kp Y                &kp U  &kp I                    &kp O                     &kp P
&lt 2 A           &lt 5 S       &kp D         &kp F                        &kp G               &kp LS(LG(S))               &kp MINUS      &kp H                &kp J  &kp K                    &kp L                     &mt RIGHT_SHIFT ENTER
&mt LEFT_SHIFT Z  &kp X         &kp C         &kp V                        &kp B               &kp COLON                   &kp SEMICOLON  &kp N                &kp M  &mt RIGHT_COMMAND COMMA  &mt RIGHT_COMMAND PERIOD  &lt 4 SLASH
&lt 4 A           &kp LEFT_WIN  &kp LEFT_ALT  &lt_to_layer_0 4 INT_HENKAN  &lt 2 LEFT_COMMAND  &lt_to_layer_0 1 SPACE      &kp SPACE      &lt 5 RIGHT_COMMAND                                                             &kp DEL
            >;

            // 【追加】回すだけでCommand＋スクロールが発動するカスタム設定に変更
            sensor-bindings = <&encoder_pinch_zoom>;
        };

        MOUSE {
            bindings = <
&kp LG(LC(F))  &trans  &trans  &trans  &trans                      &trans  &trans    &trans    &trans    &trans
&kp LG(TAB)    &trans  &trans  &trans  &trans  &trans      &trans  &trans  &mkp MB1  &mkp MB3  &mkp MB2  &trans
&kp LG(H)      &trans  &trans  &trans  &trans  &trans      &trans
